            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "id": "req-cart-add-item-guest",
          "name": "Add Item (Guest)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.guestToken) {",
                  "  pm.collectionVariables.set('guestToken', res.guestToken);",
                  "  console.log('guestToken guardado:', res.guestToken);",
                  "}",
                  "if (res.items && res.items.length > 0) {",
                  "  const last = res.items[res.items.length - 1];",
                  "  pm.collectionVariables.set('cartItemId', last.id);",
                  "  console.log('cartItemId guardado:', last.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "id": "req-cart-update-item",
          "name": "Update Item Quantity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/items/:itemId",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items", ":itemId"],
              "variable": [{ "key": "itemId", "value": "{{cartItemId}}" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}"
            }
          }
        },
        {
          "id": "req-cart-remove-item",
          "name": "Remove Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/cart/items/:itemId",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "items", ":itemId"],
              "variable": [{ "key": "itemId", "value": "{{cartItemId}}" }]
            }
          }
        },
        {
          "id": "req-cart-clear",
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            }
          }
        },
        {
          "id": "req-cart-clear-guest",
          "name": "Clear Cart (Guest)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "DELETE",
            "header": [{ "key": "X-Guest-Token", "value": "{{guestToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": ["{{baseUrl}}"],
              "path": ["cart"]
            }
          }
        },
        {
          "id": "req-cart-merge",
          "name": "Merge Guest Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/merge",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "merge"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guestToken\": \"{{guestToken}}\"\n}"
            }
          }
        },
        {
          "id": "req-cart-checkout",
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
