            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"MXN\",\n  \"name\": \"Peso Mexicano\",\n  \"symbol\": \"$\",\n  \"decimalPlaces\": 2,\n  \"isDefault\": false\n}"
            }
          }
        },
        {
          "id": "req-currencies-get-active",
          "name": "Get Active Currencies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (Array.isArray(res) && res.length > 0) {",
                  "  const usd = res.find(c => c.code === 'USD') || res[0];",
                  "  pm.collectionVariables.set('currencyId', usd.id);",
                  "  pm.collectionVariables.set('fromCurrencyId', usd.id);",
                  "  console.log('currencyId (USD) guardado:', usd.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/currencies",
              "host": ["{{baseUrl}}"],
              "path": ["currencies"]
            }
          }
        },
        {
          "id": "req-currencies-get-all",
          "name": "Get All Currencies (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/currencies/all",
              "host": ["{{baseUrl}}"],
              "path": ["currencies", "all"]
            }
          }
        },
        {
          "id": "req-currencies-toggle",
          "name": "Toggle Currency Active",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/currencies/:id/toggle",
              "host": ["{{baseUrl}}"],
              "path": ["currencies", ":id", "toggle"],
              "variable": [{ "key": "id", "value": "{{currencyId}}" }]
            }
          }
        },
        {
          "id": "req-exchange-rates-create",
          "name": "Create Exchange Rate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/currencies/exchange-rates",
              "host": ["{{baseUrl}}"],
              "path": ["currencies", "exchange-rates"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromCurrencyId\": \"{{fromCurrencyId}}\",\n  \"toCurrencyId\": \"{{toCurrencyId}}\",\n  \"rate\": 17.15,\n  \"effectiveDate\": \"2026-04-04\"\n}"
            }
          }
        },
        {
          "id": "req-exchange-rates-get-latest",
          "name": "Get Latest Rate (USD → MXN)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/currencies/exchange-rates/:from/:to",
              "host": ["{{baseUrl}}"],
              "path": ["currencies", "exchange-rates", ":from", ":to"],
              "variable": [
                { "key": "from", "value": "USD" },
                { "key": "to", "value": "MXN" }
              ]
            }
          }
        },
        {
          "id": "req-currencies-convert",
          "name": "Convert Amount",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/currencies/convert?from=USD&to=MXN&amount=100",
