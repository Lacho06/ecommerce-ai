                  "  console.log('orderId guardado:', res.id);",
                  "  console.log('Moneda de la orden:', res.currencyCode, res.currencySymbol);",
                  "  if (res.items && res.items.length > 0) {",
                  "    const item = res.items[0];",
                  "    console.log('Item[0] moneda producto:', item.currencyCode);",
                  "    console.log('Item[0] moneda base:', item.baseCurrencyCode);",
                  "    console.log('Item[0] tasa de cambio:', item.exchangeRate);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
