# Milvus (vector database)
MILVUS_HOST=milvus
MILVUS_PORT=19530

# Backend NestJS
BACKEND_URL=http://backend:3000

# Groq API (primary LLM - free tier: 14,400 req/day)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Google Gemini API (vision + fallback - free tier: 1,500 req/day)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Embedding model (local, runs on CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Redis (for chat history caching)
REDIS_URL=redis://redis:6379/1

# Service-to-service auth
AI_SERVICE_SECRET=change-this-secret
